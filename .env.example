# ── Connection Mode ──────────────────────────────────────────────
# "connect" = attach to your running browser (recommended)
# "launch"  = start a fresh browser (original behavior)
# "auto"    = try connect first, fall back to launch
SCOUT_MODE=auto

# Explicit browser debug URL (overrides discovery)
# SCOUT_CONNECT_URL=http://localhost:9222

# ── Browser ─────────────────────────────────────────────────────
SCOUT_BROWSER=chromium
SCOUT_HEADLESS=false
SCOUT_VIEWPORT_WIDTH=1280
SCOUT_VIEWPORT_HEIGHT=800
SCOUT_CDP_PORT=9229
SCOUT_MAX_ELEMENTS=1000
SCOUT_MAX_TABS=10

# Persistent profile (only for "launch" mode)
# SCOUT_PROFILE_DIR=

# Login tool (disabled by default)
SCOUT_LOGIN_ENABLED=false

# HTTP dispatch server (optional — set a port to enable)
SCOUT_LCP_PORT=
# Secret for LCP auth (optional — if set, requires X-Scout-Secret header on POST endpoints)
# SCOUT_LCP_SECRET=
